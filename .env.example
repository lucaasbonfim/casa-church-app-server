PORT=3000
FRONTEND_URL=http://localhost:5173

PGHOST=localhost
PGDATABASE=casa_church
PGUSER=postgres
PGPASSWORD=postgres
PGSSLMODE=disable
PGCHANNELBINDING=disable
PGPORT=5432

JWT_SECRET=change-me
JWT_TOKEN_AUDIENCE=casa-church-web
JWT_TOKEN_ISSUER=casa-church-server
JWT_TTL=3600

EMAIL_VERIFICATION_TTL_MINUTES=1440
PASSWORD_RESET_TTL_MINUTES=30
EMAIL_FROM="Casa Church <noreply@casachurch.com>"
# Opcional. Se vazio, emails via Brevo usam FRONTEND_URL/logo-email.png.
EMAIL_LOGO_URL=

# Brevo HTTP API. Quando configurado, tem prioridade sobre SMTP.
BREVO_API_KEY=
# Compatibilidade com a variavel usada no Grana Control.
API_MCP_REVO=

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
